# Database (required)
DATABASE_URL="file:./dev.db"

# Claude API (required for AI features — packing list, meal planning)
# ANTHROPIC_API_KEY=your_key_here

# OpenAI API (required for voice transcription — Whisper API)
# Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_key_here

# Google Maps (optional — for Routes API + Places search)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Weather: uses Open-Meteo (free, no key needed)

# Voyage AI (required for knowledge base embeddings — Phase 3)
# Get key at https://dash.voyageai.com → API Keys
# VOYAGE_API_KEY=your_key_here

# Gmail (required for float plan email — Phase 7)
# Enable 2-Step Verification first: myaccount.google.com > Security
# Then create App Password: myaccount.google.com > Security > App passwords
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password
