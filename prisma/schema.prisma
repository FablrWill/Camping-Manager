generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GearItem {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  category    String   // see lib/gear-categories.ts for full list
  description String?
  condition   String?  // new, good, fair, worn, broken
  weight      Float?   // in pounds
  photoUrl    String?
  storageLocation String?
  isWishlist  Boolean  @default(false)
  purchaseUrl String?
  price       Float?
  notes       String?
  wattage     Float?   // power draw in watts (consumers) or peak output (solar panel)
  hoursPerDay Float?   // default daily usage hours; falls back to lookup table if null
  hasBattery  Boolean  @default(false) // has internal rechargeable battery — reminder to charge before trips
  modelNumber   String?  // e.g. "ESP32-WROOM-32"
  connectivity  String?  // e.g. "WiFi, Bluetooth"
  manualUrl     String?  // URL to product manual
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packingItems PackingItem[]
}

model Vehicle {
  id              String   @id @default(cuid())
  name            String   // e.g. "2022 Santa Fe Hybrid"
  year            Int?
  make            String?
  model           String?
  drivetrain      String?
  fuelEconomy     String?
  groundClearance Float?
  towingCapacity  Int?
  cargoVolume     Float?   // cu ft behind 2nd row
  cargoLength     Float?   // inches, seats folded
  cargoWidth      Float?   // inches between wheel wells
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mods    VehicleMod[]
  trips   Trip[]
}

model VehicleMod {
  id          String   @id @default(cuid())
  vehicleId   String
  name        String
  description String?
  installedAt DateTime?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  latitude      Float?
  longitude     Float?
  type          String?  // dispersed, campground, overlook, water_access
  description   String?
  rating        Int?     // 1-5
  roadCondition String?
  clearanceNeeded String?
  cellSignal    String?  // none, weak, moderate, strong
  starlinkSignal String? // none, weak, moderate, strong
  waterAccess   Boolean  @default(false)
  visitedAt     DateTime?
  photoUrl      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips  Trip[]
  photos Photo[]
}

model Photo {
  id                  String    @id @default(cuid())
  title               String
  latitude            Float?    // nullable for unplaced photos
  longitude           Float?
  altitude            Float?
  takenAt             DateTime?
  imagePath           String    // /photos/[cuid].jpg (compressed copy)
  locationId          String?
  tripId              String?
  locationSource      String?   // "exif" | "vision" | null
  locationDescription String?   // AI-inferred place name
  locationConfidence  String?   // "high" | "medium" | "low"
  visionApproximate   Boolean   @default(false)
  googleUrl           String?   // link to Google Photos
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  trip     Trip?     @relation(fields: [tripId], references: [id])

  @@index([locationId])
  @@index([tripId])
  @@index([takenAt])
}

// --- Timeline Models (from Google Maps Location History) ---

model TimelinePoint {
  id           String   @id @default(cuid())
  latitude     Float
  longitude    Float
  altitude     Float?
  timestamp    DateTime
  timestampMs  BigInt
  accuracy     Int?
  activityType String?  // ON_FOOT, IN_VEHICLE, HIKING, etc.
  createdAt    DateTime @default(now())

  @@index([timestamp])
  @@index([timestampMs])
}

model PlaceVisit {
  id              String   @id @default(cuid())
  name            String
  address         String?
  latitude        Float
  longitude       Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  confidence      String   @default("UNKNOWN")
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model ActivitySegment {
  id              String   @id @default(cuid())
  activityType    String   // HIKING, IN_VEHICLE, CYCLING, etc.
  startLat        Float
  startLon        Float
  endLat          Float
  endLon          Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  distanceMeters  Int?
  waypoints       String?  // JSON array of {lat, lon} pairs
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  locationId  String?
  vehicleId   String?
  notes       String?
  weatherNotes String?
  currentBatteryPct  Float?    // last known EcoFlow battery %, entered during live mode
  batteryUpdatedAt   DateTime? // when currentBatteryPct was last set
  mealPlanGeneratedAt DateTime? // set when Claude generates a meal plan for this trip
  packingListResult      String?   // JSON blob of PackingListResult (D-01)
  packingListGeneratedAt DateTime? // when packing list was last generated (D-01)
  cachedAt               DateTime? // Phase 8 offline snapshot (D-11)
  emergencyContactName   String?   // per-trip override for emergency contact name (Phase 7)
  emergencyContactEmail  String?   // per-trip override for emergency contact email (Phase 7)
  bringingDog            Boolean   @default(false)  // Phase 19: dog-aware trip planning
  permitUrl              String?   // Phase 21: Recreation.gov or other booking confirmation URL
  permitNotes            String?   // Phase 21: site number, check-in time, special instructions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location           Location?          @relation(fields: [locationId], references: [id])
  vehicle            Vehicle?           @relation(fields: [vehicleId], references: [id])
  packingItems       PackingItem[]
  photos             Photo[]
  mealPlan           MealPlan?
  tripFeedbacks      TripFeedback[]
  departureChecklist DepartureChecklist?
  floatPlanLogs      FloatPlanLog[]
}

model PackingItem {
  id          String    @id @default(cuid())
  tripId      String
  gearId      String
  packed      Boolean   @default(false)
  notes       String?
  usageStatus String?   // "used" | "didn't need" | "forgot but needed" | null
  cachedAt    DateTime? // Phase 8 offline snapshot (D-11)

  trip Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  gear GearItem @relation(fields: [gearId], references: [id], onDelete: Cascade)

  @@unique([tripId, gearId])
  @@index([tripId])
  @@index([gearId])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  source     String   // file path or URL, e.g. "data/research/dispersed-camping-regulations.md"
  title      String   // heading text or document title
  content    String   // plain text chunk, target 256-512 tokens
  embedding  Bytes    // Float32Array as BLOB — 512 dims for voyage-3-lite
  metadata   String   // JSON: { topic, region, category, confidence, verifyFlag }
  chunkIdx   Int      // 0-based position within source document
  tokenCount Int      // estimated token count for this chunk
  createdAt  DateTime @default(now())

  @@index([source])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?   // auto-set from first user message, editable
  context   String?   // JSON: page context passed when opening chat from other pages
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool_result"
  content        String   // text content or JSON for tool calls/results
  toolCallId     String?  // populated for tool_result role messages
  toolName       String?  // name of tool called, if role is tool_result
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AgentMemory {
  id        String   @id @default(cuid())
  key       String   @unique  // e.g. "camping_style", "dietary_restrictions", "preferred_regions"
  value     String   // plain text or JSON value
  updatedAt DateTime @updatedAt

  @@index([key])
}

model MealPlan {
  id          String    @id @default(cuid())
  tripId      String    @unique  // one meal plan per trip (D-05)
  result      String    // JSON blob of MealPlanResult
  generatedAt DateTime  @default(now())
  cachedAt    DateTime? // Phase 8 offline snapshot (D-11)
  createdAt   DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripFeedback {
  id              String    @id @default(cuid())
  tripId          String    // NOT unique — append-only, multiple records per trip (D-09)
  summary         String?   // free text summary
  voiceTranscript String?   // raw voice transcript
  insights        String?   // JSON: structured extracted insights
  status          String    @default("pending") // "pending" | "applied"
  createdAt       DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// --- Phase 7: Day-of Execution Models ---

model DepartureChecklist {
  id          String   @id @default(cuid())
  tripId      String   @unique
  result      String   // JSON: { slots: [{ label, items: [{ id, text, checked, isUnpackedWarning }] }] }
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model FloatPlanLog {
  id         String   @id @default(cuid())
  tripId     String
  sentTo     String
  sentToName String?
  subject    String
  body       String
  sentAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Settings {
  id                    String   @id @default("user_settings") // singleton — always the same row
  emergencyContactName  String?
  emergencyContactEmail String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SharedLocation {
  id        String   @id @default(cuid())
  slug      String   @unique
  lat       Float
  lon       Float
  label     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model InboxItem {
  id           String    @id @default(cuid())
  sourceType   String    // "text" | "url" | "image"
  rawContent   String    // original input: text content, URL, or image path
  status       String    @default("pending")  // "pending" | "accepted" | "rejected"
  triageType   String?   // "gear" | "location" | "knowledge" | "tip" | "unknown"
  suggestion   String?   // JSON blob of extracted suggestion (GearDraft, LocationDraft, etc.)
  summary      String?   // human-readable one-liner of what was found
  confidence   String?   // "high" | "medium" | "low"
  imagePath    String?   // stored image path if sourceType=image
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}
