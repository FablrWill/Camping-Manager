generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GearItem {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  category    String   // see lib/gear-categories.ts for full list
  description String?
  condition   String?  // new, good, fair, worn, broken
  weight      Float?   // in pounds
  photoUrl    String?
  storageLocation String?
  isWishlist  Boolean  @default(false)
  purchaseUrl String?
  price       Float?
  notes       String?
  wattage     Float?   // power draw in watts (consumers) or peak output (solar panel)
  hoursPerDay Float?   // default daily usage hours; falls back to lookup table if null
  hasBattery  Boolean  @default(false) // has internal rechargeable battery — reminder to charge before trips
  modelNumber   String?  // e.g. "ESP32-WROOM-32"
  connectivity  String?  // e.g. "WiFi, Bluetooth"
  researchResult  String?   // JSON: { alternatives: [...], summary, recommendation }
  researchedAt    DateTime? // when research was last run — stale after 90 days
  targetPrice     Float?    // Phase 32: deal monitoring target price
  lastMaintenanceAt     DateTime? // S27: last time maintenance was logged
  maintenanceIntervalDays Int?    // S27: reminder interval in days (null = no reminder)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packingItems     PackingItem[]
  documents        GearDocument[]
  priceCheck       GearPriceCheck?
  maintenanceLogs  GearMaintenanceLog[]
  loans            GearLoan[]
}

// --- S27: Gear Maintenance Reminders ---

model GearMaintenanceLog {
  id         String   @id @default(cuid())
  gearItemId String
  event      String   // "cleaned" | "resealed" | "serviced" | "charged" | "inspected" | "repaired" | "other"
  notes      String?
  loggedAt   DateTime @default(now())
  gearItem   GearItem @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@index([gearItemId])
}

// --- S26: Gear Lending Tracker ---

model GearLoan {
  id           String    @id @default(cuid())
  gearItemId   String
  borrowerName String
  lentAt       DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  gearItem GearItem @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@index([gearItemId])
  @@index([returnedAt])
}

// --- Phase 32: Deal Monitoring ---

model GearPriceCheck {
  id               String   @id @default(cuid())
  gearItemId       String   @unique
  gearItem         GearItem @relation(fields: [gearItemId], references: [id], onDelete: Cascade)
  foundPriceRange  String
  foundPriceLow    Float
  retailers        String   @default("[]")
  disclaimer       String
  isAtOrBelowTarget Boolean @default(false)
  checkedAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Vehicle {
  id              String   @id @default(cuid())
  name            String   // e.g. "2022 Santa Fe Hybrid"
  year            Int?
  make            String?
  model           String?
  drivetrain      String?
  fuelEconomy     String?
  groundClearance Float?
  towingCapacity  Int?
  cargoVolume     Float?   // cu ft behind 2nd row
  cargoLength     Float?   // inches, seats folded
  cargoWidth      Float?   // inches between wheel wells
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mods    VehicleMod[]
  trips   Trip[]
}

model VehicleMod {
  id          String   @id @default(cuid())
  vehicleId   String
  name        String
  description String?
  installedAt DateTime?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  latitude      Float?
  longitude     Float?
  altitude      Float?   // meters, from EXIF on photo import
  type          String?  // dispersed, campground, overlook, water_access
  description   String?
  rating        Int?     // 1-5
  roadCondition String?
  clearanceNeeded String?
  cellSignal    String?  // none, weak, moderate, strong
  starlinkSignal String? // none, weak, moderate, strong
  waterAccess   Boolean  @default(false)
  visitedAt     DateTime?
  photoUrl      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips           Trip[]
  photos          Photo[]
  signalLogs      SignalLog[]
  seasonalRatings SeasonalRating[]
}

model SeasonalRating {
  id         String   @id @default(cuid())
  locationId String
  season     String   // "spring" | "summer" | "fall" | "winter"
  rating     Int      // 1-5
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, season])
  @@index([locationId])
}

model SignalLog {
  id              String   @id @default(cuid())
  locationId      String
  location        Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  carrier         String?   // "Verizon", "T-Mobile", "AT&T"
  cellBars        Int?      // 0-4 signal bars
  cellType        String?   // "none", "3G", "LTE", "5G"
  signalStrength  Int?      // raw dBm from HA Companion (e.g. -85)
  starlinkQuality String?   // "none", "weak", "moderate", "strong", "excellent"
  speedDown       Float?    // Mbps download
  speedUp         Float?    // Mbps upload
  notes           String?
  loggedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([locationId])
  @@index([loggedAt])
}

model Photo {
  id                  String    @id @default(cuid())
  title               String
  latitude            Float?    // nullable for unplaced photos
  longitude           Float?
  altitude            Float?
  takenAt             DateTime?
  imagePath           String    // /photos/[cuid].jpg (compressed copy)
  locationId          String?
  tripId              String?
  locationSource      String?   // "exif" | "vision" | null
  locationDescription String?   // AI-inferred place name
  locationConfidence  String?   // "high" | "medium" | "low"
  visionApproximate   Boolean   @default(false)
  googleUrl           String?   // link to Google Photos
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  trip     Trip?     @relation(fields: [tripId], references: [id])

  @@index([locationId])
  @@index([tripId])
  @@index([takenAt])
}

// --- Timeline Models (from Google Maps Location History) ---

model TimelinePoint {
  id           String   @id @default(cuid())
  latitude     Float
  longitude    Float
  altitude     Float?
  timestamp    DateTime
  timestampMs  BigInt
  accuracy     Int?
  activityType String?  // ON_FOOT, IN_VEHICLE, HIKING, etc.
  createdAt    DateTime @default(now())

  @@index([timestamp])
  @@index([timestampMs])
}

model PlaceVisit {
  id              String   @id @default(cuid())
  name            String
  address         String?
  latitude        Float
  longitude       Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  confidence      String   @default("UNKNOWN")
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model ActivitySegment {
  id              String   @id @default(cuid())
  activityType    String   // HIKING, IN_VEHICLE, CYCLING, etc.
  startLat        Float
  startLon        Float
  endLat          Float
  endLon          Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  distanceMeters  Int?
  waypoints       String?  // JSON array of {lat, lon} pairs
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  locationId  String?
  vehicleId   String?
  notes       String?
  reviewedAt  DateTime? // Phase 38: set when post-trip review is submitted
  weatherNotes String?
  currentBatteryPct  Float?    // last known EcoFlow battery %, entered during live mode
  batteryUpdatedAt   DateTime? // when currentBatteryPct was last set
  mealPlanGeneratedAt DateTime? // set when Claude generates a meal plan for this trip
  packingListResult      String?   // JSON blob of PackingListResult (D-01)
  packingListGeneratedAt DateTime? // when packing list was last generated (D-01)
  cachedAt               DateTime? // Phase 8 offline snapshot (D-11)
  emergencyContactName   String?   // per-trip override for emergency contact name (Phase 7)
  emergencyContactEmail  String?   // per-trip override for emergency contact email (Phase 7)
  bringingDog            Boolean   @default(false)  // Phase 19: dog-aware trip planning
  permitUrl              String?   // Phase 21: Recreation.gov or other booking confirmation URL
  permitNotes            String?   // Phase 21: site number, check-in time, special instructions
  departureTime          DateTime? // Phase 26: departure time anchor for day sequencer
  vehicleChecklistResult      String?   // Phase 29: JSON blob of VehicleChecklistResult
  vehicleChecklistGeneratedAt DateTime? // Phase 29: when vehicle checklist was last generated
  lntChecklistResult          String?   // S25: JSON blob of LNTChecklistResult
  lntChecklistGeneratedAt     DateTime? // S25: when LNT checklist was last generated
  fallbackFor   String?   // Phase 22: ID of the primary trip this is a fallback for
  fallbackOrder Int?      // Phase 22: 2 = Plan B, 3 = Plan C
  journalEntry   String?   // S20: Voice Ghostwriter journal entry (Claude-written narrative)
  journalEntryAt DateTime? // S20: when journal entry was last generated
  shareToken     String?   @unique // S28: public share token for read-only trip report
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location           Location?          @relation(fields: [locationId], references: [id])
  vehicle            Vehicle?           @relation(fields: [vehicleId], references: [id])
  packingItems       PackingItem[]
  photos             Photo[]
  mealPlan           MealPlan?
  tripFeedbacks      TripFeedback[]
  departureChecklist DepartureChecklist?
  floatPlanLogs      FloatPlanLog[]
  expenses           TripExpense[]

  // Fallback chain self-relation (Phase 22)
  primaryTrip  Trip?   @relation("FallbackChain", fields: [fallbackFor], references: [id], onDelete: NoAction, onUpdate: NoAction)
  alternatives Trip[]  @relation("FallbackChain")
}

model PackingItem {
  id          String    @id @default(cuid())
  tripId      String
  gearId      String
  packed      Boolean   @default(false)
  notes       String?
  usageStatus String?   // "used" | "didn't need" | "forgot but needed" | null
  cachedAt    DateTime? // Phase 8 offline snapshot (D-11)

  trip Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  gear GearItem @relation(fields: [gearId], references: [id], onDelete: Cascade)

  @@unique([tripId, gearId])
  @@index([tripId])
  @@index([gearId])
}

model KnowledgeChunk {
  id          String    @id @default(cuid())
  source      String    // file path or URL, e.g. "data/research/dispersed-camping-regulations.md"
  title       String    // heading text or document title
  content     String    // plain text chunk, target 256-512 tokens
  embedding   Bytes     // Float32Array as BLOB — 512 dims for voyage-3-lite
  metadata    String    // JSON: { topic, region, category, confidence, verifyFlag }
  chunkIdx    Int       // 0-based position within source document
  tokenCount  Int       // estimated token count for this chunk
  contentHash String?   // SHA-256 of chunk content for change detection
  refreshedAt DateTime? // when chunk was last refreshed from source
  createdAt   DateTime  @default(now())

  @@index([source])
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?   // auto-set from first user message, editable
  context   String?   // JSON: page context passed when opening chat from other pages
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool_result"
  content        String   // text content or JSON for tool calls/results
  toolCallId     String?  // populated for tool_result role messages
  toolName       String?  // name of tool called, if role is tool_result
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AgentMemory {
  id        String   @id @default(cuid())
  key       String   @unique  // e.g. "camping_style", "dietary_restrictions", "preferred_regions"
  value     String   // plain text or JSON value
  summary   String?  // S33: rolling AI-condensed digest of all entries (< 500 tokens); only the singleton row with key="__summary__" uses this
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model MealPlan {
  id          String   @id @default(cuid())
  tripId      String   @unique
  generatedAt DateTime @default(now())
  notes       String?
  prepGuide   String?  // JSON: PrepGuideResult persisted after generation
  createdAt   DateTime @default(now())

  trip              Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  meals             Meal[]
  shoppingListItems ShoppingListItem[]
  feedbacks         MealFeedback[]
}

model Meal {
  id               String   @id @default(cuid())
  mealPlanId       String
  day              Int
  slot             String
  name             String
  description      String?
  ingredients      String
  cookInstructions String?
  prepNotes        String?
  estimatedMinutes Int?
  createdAt        DateTime @default(now())

  mealPlan  MealPlan       @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  feedbacks MealFeedback[]

  @@index([mealPlanId])
  @@index([mealPlanId, day, slot])
}

model ShoppingListItem {
  id         String   @id @default(cuid())
  mealPlanId String
  item       String
  quantity   String
  unit       String   @default("")
  category   String   @default("other")
  checked    Boolean  @default(false)
  createdAt  DateTime @default(now())

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
}

model MealFeedback {
  id         String   @id @default(cuid())
  mealId     String?
  mealPlanId String
  mealName   String
  rating     String   // "liked" | "disliked"
  notes      String?
  createdAt  DateTime @default(now())

  meal     Meal?    @relation(fields: [mealId], references: [id], onDelete: SetNull)
  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@index([mealPlanId])
  @@index([mealId])
  @@index([createdAt])
}

model TripFeedback {
  id              String    @id @default(cuid())
  tripId          String    // NOT unique — append-only, multiple records per trip (D-09)
  summary         String?   // free text summary
  voiceTranscript String?   // raw voice transcript
  insights        String?   // JSON: structured extracted insights
  status          String    @default("pending") // "pending" | "applied"
  createdAt       DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

// --- Medications (global profile, reused across all trips) ---

model Medication {
  id           String   @id @default(cuid())
  name         String
  dosesPerDay  Float                     // e.g., 2 = twice daily
  unitsPerDose Float    @default(1)      // e.g., 1 pill per dose
  unit         String   @default("pill") // pill, tablet, ml, etc.
  isForDog     Boolean  @default(false)  // true = dog's medication
  notes        String?
  createdAt    DateTime @default(now())
}

// --- Phase 7: Day-of Execution Models ---

model DepartureChecklist {
  id          String   @id @default(cuid())
  tripId      String   @unique
  result      String   // JSON: { slots: [{ label, items: [{ id, text, checked, isUnpackedWarning }] }] }
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model FloatPlanLog {
  id         String   @id @default(cuid())
  tripId     String
  sentTo     String
  sentToName String?
  subject    String
  body       String
  sentAt     DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Settings {
  id                    String   @id @default("user_settings") // singleton — always the same row
  emergencyContactName  String?
  emergencyContactEmail String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model CampingProfile {
  id           String   @id @default("singleton") // singleton — always the same row
  reportJson   String
  generatedAt  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SharedLocation {
  id        String   @id @default(cuid())
  slug      String   @unique
  lat       Float
  lon       Float
  label     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model InboxItem {
  id           String    @id @default(cuid())
  sourceType   String    // "text" | "url" | "image"
  rawContent   String    // original input: text content, URL, or image path
  status       String    @default("pending")  // "pending" | "accepted" | "rejected"
  triageType   String?   // "gear" | "location" | "knowledge" | "tip" | "unknown"
  suggestion   String?   // JSON blob of extracted suggestion (GearDraft, LocationDraft, etc.)
  summary      String?   // human-readable one-liner of what was found
  confidence   String?   // "high" | "medium" | "low"
  imagePath    String?   // stored image path if sourceType=image
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}

// --- Phase 36: Agent Jobs Infrastructure ---

model AgentJob {
  id            String    @id @default(cuid())
  type          String    // "gear_enrichment" | "weather_analysis" | "deal_check" | etc.
  status        String    @default("pending") // pending | running | done | failed
  triggeredBy   String    @default("manual") // manual | schedule | auto
  payload       String    // JSON input
  result        String?   // JSON output (null until done)
  readAt        DateTime? // null until user acknowledges the result
  scheduledFor  DateTime? // when this job should next run (scheduler template jobs)
  recurringCron String?   // cron expression: "0 8 * * *" = 8am daily
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([scheduledFor])
}

// --- Camp Kit Presets ---

model KitPreset {
  id          String   @id @default(cuid())
  name        String   // "Weekend Warrior", "Remote Office", "Extended Stay"
  description String?
  gearIds     String   // JSON array of gear item IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Phase 25: Gear Docs & Manual Finder ---

model GearDocument {
  id         String   @id @default(cuid())
  gearItemId String
  type       String   // "manual_pdf" | "support_link" | "warranty" | "product_page"
  url        String
  title      String
  localPath  String?  // set when PDF downloaded, e.g. /docs/abc123.pdf
  createdAt  DateTime @default(now())

  gearItem GearItem @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@index([gearItemId])
}

// --- Trip Cost Tracking ---

model TripExpense {
  id          String    @id @default(cuid())
  tripId      String
  category    String    // "gas", "permits", "groceries", "food", "gear", "campsite", "other"
  description String
  amount      Float
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}
