generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GearItem {
  id          String   @id @default(cuid())
  name        String
  brand       String?
  category    String   // shelter, sleep, cook, power, clothing, tools, vehicle
  description String?
  condition   String?  // new, good, fair, worn, broken
  weight      Float?   // in pounds
  photoUrl    String?
  storageLocation String?
  isWishlist  Boolean  @default(false)
  purchaseUrl String?
  price       Float?
  notes       String?
  wattage     Float?   // power draw in watts (consumers) or peak output (solar panel)
  hoursPerDay Float?   // default daily usage hours; falls back to lookup table if null
  hasBattery  Boolean  @default(false) // has internal rechargeable battery — reminder to charge before trips
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  packingItems PackingItem[]
}

model Vehicle {
  id              String   @id @default(cuid())
  name            String   // e.g. "2022 Santa Fe Hybrid"
  year            Int?
  make            String?
  model           String?
  drivetrain      String?
  fuelEconomy     String?
  groundClearance Float?
  towingCapacity  Int?
  cargoVolume     Float?   // cu ft behind 2nd row
  cargoLength     Float?   // inches, seats folded
  cargoWidth      Float?   // inches between wheel wells
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mods    VehicleMod[]
  trips   Trip[]
}

model VehicleMod {
  id          String   @id @default(cuid())
  vehicleId   String
  name        String
  description String?
  installedAt DateTime?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  latitude      Float?
  longitude     Float?
  type          String?  // dispersed, campground, overlook, water_access
  description   String?
  rating        Int?     // 1-5
  roadCondition String?
  clearanceNeeded String?
  cellSignal    String?  // none, weak, moderate, strong
  starlinkSignal String? // none, weak, moderate, strong
  waterAccess   Boolean  @default(false)
  visitedAt     DateTime?
  photoUrl      String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips  Trip[]
  photos Photo[]
}

model Photo {
  id                  String    @id @default(cuid())
  title               String
  latitude            Float?    // nullable for unplaced photos
  longitude           Float?
  altitude            Float?
  takenAt             DateTime?
  imagePath           String    // /photos/[cuid].jpg (compressed copy)
  locationId          String?
  tripId              String?
  locationSource      String?   // "exif" | "vision" | null
  locationDescription String?   // AI-inferred place name
  locationConfidence  String?   // "high" | "medium" | "low"
  visionApproximate   Boolean   @default(false)
  googleUrl           String?   // link to Google Photos
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  trip     Trip?     @relation(fields: [tripId], references: [id])

  @@index([locationId])
  @@index([tripId])
  @@index([takenAt])
}

// --- Timeline Models (from Google Maps Location History) ---

model TimelinePoint {
  id           String   @id @default(cuid())
  latitude     Float
  longitude    Float
  altitude     Float?
  timestamp    DateTime
  timestampMs  BigInt
  accuracy     Int?
  activityType String?  // ON_FOOT, IN_VEHICLE, HIKING, etc.
  createdAt    DateTime @default(now())

  @@index([timestamp])
  @@index([timestampMs])
}

model PlaceVisit {
  id              String   @id @default(cuid())
  name            String
  address         String?
  latitude        Float
  longitude       Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  confidence      String   @default("UNKNOWN")
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model ActivitySegment {
  id              String   @id @default(cuid())
  activityType    String   // HIKING, IN_VEHICLE, CYCLING, etc.
  startLat        Float
  startLon        Float
  endLat          Float
  endLon          Float
  startTimestamp  DateTime
  endTimestamp    DateTime
  startMs         BigInt
  endMs           BigInt
  durationMinutes Int
  distanceMeters  Int?
  waypoints       String?  // JSON array of {lat, lon} pairs
  createdAt       DateTime @default(now())

  @@index([startTimestamp])
  @@index([startMs])
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  locationId  String?
  vehicleId   String?
  notes       String?
  weatherNotes String?
  currentBatteryPct  Float?    // last known EcoFlow battery %, entered during live mode
  batteryUpdatedAt   DateTime? // when currentBatteryPct was last set
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location     Location? @relation(fields: [locationId], references: [id])
  vehicle      Vehicle?  @relation(fields: [vehicleId], references: [id])
  packingItems PackingItem[]
  photos       Photo[]
}

model PackingItem {
  id       String  @id @default(cuid())
  tripId   String
  gearId   String
  packed   Boolean @default(false)
  notes    String?

  trip Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  gear GearItem @relation(fields: [gearId], references: [id], onDelete: Cascade)

  @@unique([tripId, gearId])
  @@index([tripId])
  @@index([gearId])
}
